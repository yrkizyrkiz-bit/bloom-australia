  createdAt   DateTime @default(now())

  @@unique([doctorId, blockedDate])
  @@index([doctorId])
  @@index([blockedDate])
}

// GAP-009+: Weight Management Intake record for durable tracking
// Links patient, booking, payment, and program enrollment
model WeightManagementIntake {
  id                    String                @id @default(cuid())

  // Patient link (required)
  userId                String
  user                  User                  @relation(fields: [userId], references: [id], onDelete: Cascade)

  // Program enrollment link (optional - created after intake)
  programMemberId       String?               @unique

  // Booking link (optional - created when slot selected)
  bookingId             String?               @unique

  // Prescription link (optional - created after doctor approval)
  prescriptionId        String?               @unique

  // Selected plan
  selectedPlan          WMPlanType            @default(CORE)

  // Payment tracking
  paymentStatus         WMPaymentStatus       @default(UNPAID)
  paymentIntentId       String?
  paymentAmount         Int?                  // cents
  paidAt                DateTime?

  // Booking status (denormalized for quick access)
  bookingStatus         WMBookingStatus       @default(NOT_BOOKED)
  scheduledAt           DateTime?

  // Doctor review status
  doctorReviewStatus    WMDoctorReviewStatus  @default(PENDING_TRIAGE)
  doctorId              String?
  doctorReviewedAt      DateTime?
  doctorDecision        String?               // APPROVED, DECLINED, PENDING_TESTS, etc.
  doctorNotes           String?

  // Portal status
  portalStatus          WMPortalStatus        @default(INTAKE_STARTED)
  portalActivatedAt     DateTime?

  // Quiz data (full intake form data)
  quizData              Json?

  // Metadata
  source                String?               @default("quiz")
  createdAt             DateTime              @default(now())
  updatedAt             DateTime              @updatedAt
  completedAt           DateTime?

  @@index([userId])
  @@index([paymentStatus])
  @@index([bookingStatus])
  @@index([doctorReviewStatus])
  @@index([portalStatus])
  @@index([createdAt])
}

