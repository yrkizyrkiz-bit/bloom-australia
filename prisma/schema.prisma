// GAP-009: Doctor availability/roster for real calendar-based booking
model DoctorAvailability {
  id              String                  @id @default(cuid())
  doctorId        String
  dayOfWeek       Int                     // 0=Sunday, 1=Monday, ..., 6=Saturday
  startTime       String                  // "09:00" format (24hr)
  endTime         String                  // "17:00" format (24hr)
  slotDuration    Int                     @default(30) // minutes per slot
  isRecurring     Boolean                 @default(true)
  specificDate    DateTime?               // For non-recurring availability
  maxBookings     Int                     @default(1) // Per slot
  status          DoctorAvailabilityStatus @default(AVAILABLE)
  notes           String?
  createdAt       DateTime                @default(now())
  updatedAt       DateTime                @updatedAt

  @@index([doctorId])
  @@index([dayOfWeek])
  @@index([status])
  @@index([specificDate])
}

