generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@index([userId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model User {
  id                              String                  @id @default(cuid())
  email                           String                  @unique
  emailVerified                   DateTime?
  passwordHash                    String?
  password                        String?
  firstName                       String
  lastName                        String
  dateOfBirth                     DateTime?
  gender                          Gender                  @default(OTHER)
  phone                           String?
  address                         String?
  addressLine1                    String?
  addressLine2                    String?
  suburb                          String?
  state                           String?
  postcode                        String?
  country                         String?                 @default("Australia")
  mailingAddressSameAsResidential Boolean                 @default(true)
  mailingAddress                  String?
  mailingAddressLine1             String?
  mailingAddressLine2             String?
  mailingSuburb                   String?
  mailingState                    String?
  mailingPostcode                 String?
  mailingCountry                  String?                 @default("Australia")
  role                            UserRole                @default(MEMBER)
  subscriptionStatus              SubscriptionStatus      @default(INACTIVE)
  subscriptionTier                String?
  image                           String?
  createdAt                       DateTime                @default(now())
  updatedAt                       DateTime                @updatedAt
  journeyStatus                   JourneyStatus           @default(LEAD)
  leadSource                      String?
  triageScore                     Int?
  approvalStatus                  ApprovalStatus          @default(PENDING)
  engagementScore                 Int?
  churnRiskScore                  Int?
  referralCode                    String?                 @unique
  referredBy                      String?
  ltv                             Float?                  @default(0)
  renewalDate                     DateTime?
  assignedCarePartnerId           String?
  marketingOptIn                  Boolean                 @default(false)
  unsubscribedAt                  DateTime?
  aiAnalysisCache                 AIAnalysisCache[]
  aiAnalysisHistory               AIAnalysisHistory[]
  aiReports                       AIReport[]
  accounts                        Account[]
  activityLogs                    ActivityLog[]
  appointments                    Appointment[]
  automationLogs                  AutomationLog[]
  biomarkerResults                BiomarkerResult[]
  bloodPressureReadings           BloodPressureReading[]
  careCommunications              CareCommunication[]
  consultationBookings            ConsultationBooking[]
  exerciseLogs                    ExerciseLog[]
  healthGoals                     HealthGoal[]
  healthProfile                   HealthProfile?
  healthScores                    HealthScore[]
  internalNotes                   InternalNote[]
  invoices                        Invoice[]
  labReports                      LabReport[]
  mealLogs                        MealLog[]
  membershipSubscription          MembershipSubscription?
  notifications                   Notification[]
  reminders                       Reminder[]
  sessions                        Session[]
  weeklyCheckIns                  WeeklyCheckIn[]
  weightGoals                     WeightGoal[]
  weightLogs                      WeightLog[]
  prescriptions                   Prescription[]
  weightManagementIntakes         WeightManagementIntake[]

  @@index([email])
  @@index([role])
  @@index([journeyStatus])
  @@index([subscriptionTier])
}

model HealthProfile {
  id                String            @id @default(cuid())
  userId            String            @unique
  systolicBP        Int?
  diastolicBP       Int?
  onBPMedication    Boolean           @default(false)
  bpMeasuredAt      DateTime?
  smokingStatus     SmokingStatus     @default(NEVER)
  race              Race              @default(OTHER)
  familyHistoryCVD  Boolean           @default(false)
  exerciseFrequency ExerciseFrequency @default(MODERATE)
  createdAt         DateTime          @default(now())
  updatedAt         DateTime          @updatedAt
  user              User              @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model BloodPressureReading {
  id              String          @id @default(cuid())
  userId          String
  systolicBP      Int
  diastolicBP     Int
  heartRate       Int?
  measurementTime MeasurementTime @default(MORNING)
  armUsed         Arm             @default(LEFT)
  position        Position        @default(SITTING)
  notes           String?
  measuredAt      DateTime        @default(now())
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt
  user            User            @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([measuredAt])
}

model BiomarkerDefinition {
  id                  String            @id @default(cuid())
  biomarkerId         String            @unique
  name                String
  shortName           String
  category            BiomarkerCategory
  description         String
  whyItMatters        String
  unit                String
  maleRanges          Json
  femaleRanges        Json
  improvementTips     String[]          @default([])
  relatedBiomarkerIds String[]          @default([])
  isActive            Boolean           @default(true)
  sortOrder           Int               @default(0)
  createdAt           DateTime          @default(now())
  updatedAt           DateTime          @updatedAt
  results             BiomarkerResult[]
  goals               HealthGoal[]

  @@index([category])
  @@index([biomarkerId])
}

model BiomarkerResult {
  id          String              @id @default(cuid())
  userId      String
  biomarkerId String
  value       Float
  status      BiomarkerStatus
  testedAt    DateTime
  uploadedAt  DateTime            @default(now())
  uploadedBy  String?
  labReportId String?
  notes       String?
  biomarker   BiomarkerDefinition @relation(fields: [biomarkerId], references: [biomarkerId])
  labReport   LabReport?          @relation(fields: [labReportId], references: [id])
  user        User                @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([biomarkerId])
  @@index([testedAt])
  @@index([userId, biomarkerId])
}

model HealthScore {
  id               String   @id @default(cuid())
  userId           String
  overall          Int
  biologicalAge    Int?
  chronologicalAge Int?
  calculatedAt     DateTime @default(now())
  categoryScores   Json
  user             User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([calculatedAt])
}

model LabReport {
  id               String            @id @default(cuid())
  userId           String
  fileName         String
  fileUrl          String?
  fileSize         Int?
  mimeType         String?
  status           ReportStatus      @default(PENDING)
  biomarkerCount   Int               @default(0)
  uploadedAt       DateTime          @default(now())
  processedAt      DateTime?
  uploadedBy       String?
  notes            String?
  biomarkerResults BiomarkerResult[]
  user             User              @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([status])
}

model HealthGoal {
  id           String              @id @default(cuid())
  userId       String
  biomarkerId  String
  targetValue  Float
  currentValue Float
  startValue   Float
  startDate    DateTime
  targetDate   DateTime
  status       GoalStatus          @default(IN_PROGRESS)
  notes        String?
  createdAt    DateTime            @default(now())
  updatedAt    DateTime            @updatedAt
  completedAt  DateTime?
  biomarker    BiomarkerDefinition @relation(fields: [biomarkerId], references: [biomarkerId])
  user         User                @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([status])
  @@index([biomarkerId])
}

model Reminder {
  id          String            @id @default(cuid())
  userId      String
  type        ReminderType
  title       String
  description String?
  dueDate     DateTime
  frequency   ReminderFrequency @default(ONCE)
  isCompleted Boolean           @default(false)
  completedAt DateTime?
  isActive    Boolean           @default(true)
  createdAt   DateTime          @default(now())
  updatedAt   DateTime          @updatedAt
  user        User              @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([dueDate])
  @@index([isCompleted])
}

model Notification {
  id        String               @id @default(cuid())
  userId    String
  type      NotificationType
  title     String
  message   String
  category  NotificationCategory @default(SYSTEM)
  actionUrl String?
  isRead    Boolean              @default(false)
  readAt    DateTime?
  createdAt DateTime             @default(now())
  user      User                 @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([isRead])
  @@index([createdAt])
}

model AIReport {
  id                    String   @id @default(cuid())
  userId                String
  generatedAt           DateTime @default(now())
  summary               String
  keyFindings           Json
  correlations          Json
  recommendations       Json
  achievements          Json
  projectedImprovements Json
  nextSteps             String[] @default([])
  riskFactors           Json
  user                  User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([generatedAt])
}

model Appointment {
  id                 String            @id @default(cuid())
  userId             String
  type               AppointmentType
  title              String
  description        String?
  scheduledAt        DateTime
  duration           Int               @default(30)
  location           String?
  status             AppointmentStatus @default(SCHEDULED)
  notes              String?
  createdAt          DateTime          @default(now())
  updatedAt          DateTime          @updatedAt
  videoLink          String?
  carePartnerId      String?
  doctorId           String?
  isPaid             Boolean           @default(false)
  paymentId          String?
  stripePaymentId    String?           @unique
  patientBriefSent   Boolean           @default(false)
  cancellationReason String?
  followUpRequired   Boolean           @default(false)
  followUpDate       DateTime?
  referralId         String?
  user               User              @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([scheduledAt])
  @@index([status])
}

model EmailCampaign {
  id             String         @id @default(cuid())
  subject        String
  body           String
  templateId     String?
  sentBy         String
  recipientCount Int            @default(0)
  sentCount      Int            @default(0)
  deliveredCount Int            @default(0)
  openedCount    Int            @default(0)
  clickedCount   Int            @default(0)
  bouncedCount   Int            @default(0)
  status         CampaignStatus @default(DRAFT)
  scheduledAt    DateTime?
  sentAt         DateTime?
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt
  events         EmailEvent[]

  @@index([status])
  @@index([sentAt])
  @@index([sentBy])
}

model EmailEvent {
  id             String         @id @default(cuid())
  campaignId     String?
  recipientEmail String
  recipientId    String?
  messageId      String?
  eventType      EmailEventType
  metadata       Json?
  ipAddress      String?
  userAgent      String?
  createdAt      DateTime       @default(now())
  campaign       EmailCampaign? @relation(fields: [campaignId], references: [id])

  @@index([campaignId])
  @@index([recipientEmail])
  @@index([eventType])
  @@index([createdAt])
}

model EmailTemplate {
  id          String                @id @default(cuid())
  name        String
  slug        String                @unique
  category    EmailTemplateCategory
  subject     String
  body        String
  variables   String[]              @default([])
  description String?
  isActive    Boolean               @default(true)
  createdAt   DateTime              @default(now())
  updatedAt   DateTime              @updatedAt
  createdBy   String?

  @@index([category])
  @@index([slug])
}

model SMSNotification {
  id             String    @id @default(cuid())
  recipientId    String
  recipientPhone String
  message        String
  status         SMSStatus @default(PENDING)
  provider       String?
  externalId     String?
  sentAt         DateTime?
  deliveredAt    DateTime?
  errorMessage   String?
  createdAt      DateTime  @default(now())

  @@index([recipientId])
  @@index([status])
  @@index([createdAt])
}

model ActivityLog {
  id        String   @id @default(cuid())
  userId    String?
  action    String
  entity    String
  entityId  String?
  details   Json?
  ipAddress String?
  userAgent String?
  createdAt DateTime @default(now())
  user      User?    @relation(fields: [userId], references: [id])

  @@index([userId])
  @@index([action])
  @@index([entity])
  @@index([createdAt])
}

model AIAnalysisCache {
  id            String   @id @default(cuid())
  userId        String
  analysisType  String
  analysisData  Json
  biomarkerHash String
  expiresAt     DateTime
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, analysisType])
  @@index([userId])
  @@index([analysisType])
  @@index([expiresAt])
}

model AIAnalysisHistory {
  id             String   @id @default(cuid())
  userId         String
  analysisType   String
  analysisData   Json
  overallScore   Int
  riskLevel      String
  biomarkerCount Int
  createdAt      DateTime @default(now())
  user           User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([analysisType])
  @@index([createdAt])
}

model WeightLog {
  id                 String       @id @default(cuid())
  userId             String
  weight             Float
  waistCircumference Float?
  measuredAt         DateTime     @default(now())
  loggedAt           DateTime     @default(now())
  source             WeightSource @default(MANUAL)
  notes              String?
  createdAt          DateTime     @default(now())
  updatedAt          DateTime     @updatedAt
  user               User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([measuredAt])
  @@index([loggedAt])
}

model WeightGoal {
  id               String           @id @default(cuid())
  userId           String
  startWeight      Float
  targetWeight     Float
  currentWeight    Float
  startDate        DateTime         @default(now())
  targetDate       DateTime
  status           WeightGoalStatus @default(IN_PROGRESS)
  completedAt      DateTime?
  weeklyTargetLoss Float            @default(0.5)
  milestones       Json             @default("[]")
  notes            String?
  createdAt        DateTime         @default(now())
  updatedAt        DateTime         @updatedAt
  user             User             @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([status])
}

model MealLog {
  id          String   @id @default(cuid())
  userId      String
  mealType    MealType
  name        String
  description String?
  calories    Int?
  protein     Float?
  carbs       Float?
  fat         Float?
  fiber       Float?
  portionSize String?
  imageUrl    String?
  loggedAt    DateTime @default(now())
  notes       String?
  tags        String[] @default([])
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([loggedAt])
  @@index([mealType])
}

model ExerciseLog {
  id              String            @id @default(cuid())
  userId          String
  activityType    ActivityType
  name            String
  description     String?
  durationMinutes Int
  intensity       ExerciseIntensity @default(MODERATE)
  caloriesBurned  Int?
  distance        Float?
  steps           Int?
  heartRateAvg    Int?
  loggedAt        DateTime          @default(now())
  notes           String?
  createdAt       DateTime          @default(now())
  updatedAt       DateTime          @updatedAt
  user            User              @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([loggedAt])
  @@index([activityType])
}

model WeeklyCheckIn {
  id             String   @id @default(cuid())
  userId         String
  weekNumber     Int
  overallFeeling Int
  energyLevel    Int
  sleepQuality   Int
  stressLevel    Int
  focusAreas     String[] @default([])
  achievements   String[] @default([])
  challenges     String?
  weeklyGoals    Json     @default("[]")
  notes          String?
  checkedInAt    DateTime @default(now())
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  user           User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([weekNumber])
  @@index([checkedInAt])
}

model EducationalContent {
  id           String              @id @default(cuid())
  title        String
  description  String
  category     ContentCategory
  contentType  ContentType
  thumbnailUrl String?
  videoUrl     String?
  duration     Int?
  body         String?
  author       String?
  tags         String[]            @default([])
  sortOrder    Int                 @default(0)
  isPublished  Boolean             @default(true)
  isFeatured   Boolean             @default(false)
  viewCount    Int                 @default(0)
  createdAt    DateTime            @default(now())
  updatedAt    DateTime            @updatedAt
  completions  ContentCompletion[]

  @@index([category])
  @@index([contentType])
  @@index([isPublished])
}

model ContentCompletion {
  id          String             @id @default(cuid())
  userId      String
  contentId   String
  completedAt DateTime           @default(now())
  progress    Int                @default(100)
  content     EducationalContent @relation(fields: [contentId], references: [id], onDelete: Cascade)

  @@unique([userId, contentId])
  @@index([userId])
  @@index([contentId])
}

model CoachMessage {
  id            String           @id @default(cuid())
  userId        String
  coachId       String?
  message       String
  messageType   CoachMessageType @default(TEXT)
  isFromCoach   Boolean          @default(false)
  isRead        Boolean          @default(false)
  readAt        DateTime?
  attachmentUrl String?
  createdAt     DateTime         @default(now())
  updatedAt     DateTime         @updatedAt

  @@index([userId])
  @@index([coachId])
  @@index([isRead])
  @@index([createdAt])
}

model ChatSession {
  id            String            @id @default(cuid())
  memberId      String
  coachId       String?
  status        ChatSessionStatus @default(WAITING)
  isAiHandled   Boolean           @default(false)
  startedAt     DateTime          @default(now())
  endedAt       DateTime?
  lastMessageAt DateTime          @default(now())
  summary       String?
  createdAt     DateTime          @default(now())
  updatedAt     DateTime          @updatedAt
  messages      ChatMessage[]

  @@index([memberId])
  @@index([coachId])
  @@index([status])
  @@index([createdAt])
}

model ChatMessage {
  id         String         @id @default(cuid())
  sessionId  String
  senderId   String
  senderType ChatSenderType
  message    String
  isRead     Boolean        @default(false)
  readAt     DateTime?
  createdAt  DateTime       @default(now())
  session    ChatSession    @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  @@index([sessionId])
  @@index([senderId])
  @@index([createdAt])
}

model CoachAvailability {
  id           String      @id @default(cuid())
  coachId      String      @unique
  status       CoachStatus @default(OFFLINE)
  activeChats  Int         @default(0)
  maxChats     Int         @default(3)
  lastActiveAt DateTime    @default(now())
  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @updatedAt

  @@index([coachId])
  @@index([status])
}

model MemberChatHistory {
  id           String   @id @default(cuid())
  memberId     String
  sessionId    String
  coachId      String?
  coachName    String?
  wasAiHandled Boolean  @default(false)
  transcript   Json
  summary      String?
  startedAt    DateTime
  endedAt      DateTime
  messageCount Int
  createdAt    DateTime @default(now())

  @@index([memberId])
  @@index([coachId])
  @@index([createdAt])
}

model CallLog {
  id               String     @id @default(cuid())
  memberId         String
  agentId          String?
  agentName        String?
  callType         CallType   @default(OUTBOUND)
  callResult       CallResult @default(COMPLETED)
  duration         Int?
  subject          String
  notes            String?
  followUpRequired Boolean    @default(false)
  followUpDate     DateTime?
  calledAt         DateTime   @default(now())
  createdAt        DateTime   @default(now())
  updatedAt        DateTime   @updatedAt

  @@index([memberId])
  @@index([agentId])
  @@index([calledAt])
}

model InternalNote {
  id         String       @id @default(cuid())
  memberId   String?
  userId     String
  authorId   String?
  authorName String?
  createdBy  String?
  category   NoteCategory @default(GENERAL)
  title      String
  content    String
  isPinned   Boolean      @default(false)
  createdAt  DateTime     @default(now())
  updatedAt  DateTime     @updatedAt
  user       User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([memberId])
  @@index([userId])
  @@index([authorId])
  @@index([createdAt])
}

model DailyStepGoal {
  id           String    @id @default(cuid())
  userId       String
  targetSteps  Int       @default(10000)
  currentSteps Int       @default(0)
  date         DateTime  @db.Date
  isAchieved   Boolean   @default(false)
  achievedAt   DateTime?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  @@unique([userId, date])
  @@index([userId])
  @@index([date])
}

model Treatment {
  id             String           @id @default(cuid())
  userId         String
  medicationName String
  dosage         String
  frequency      String
  instructions   String?
  doctorName     String?
  pharmacyName   String?
  pharmacyPhone  String?
  startDate      DateTime
  nextDoseDate   DateTime?
  isActive       Boolean          @default(true)
  createdAt      DateTime         @default(now())
  updatedAt      DateTime         @updatedAt
  doses          MedicationDose[]

  @@index([userId])
}

model MedicationDose {
  id          String    @id @default(cuid())
  treatmentId String
  scheduledAt DateTime
  takenAt     DateTime?
  skipped     Boolean   @default(false)
  skipReason  String?
  sideEffects String[]  @default([])
  notes       String?
  createdAt   DateTime  @default(now())
  treatment   Treatment @relation(fields: [treatmentId], references: [id], onDelete: Cascade)

  @@index([treatmentId])
  @@index([scheduledAt])
}

model Recipe {
  id           String           @id @default(cuid())
  title        String
  description  String
  imageUrl     String?
  mealType     MealCategory
  dietaryTags  String[]         @default([])
  prepTime     Int
  cookTime     Int
  servings     Int
  difficulty   RecipeDifficulty @default(EASY)
  calories     Int?
  protein      Float?
  carbs        Float?
  fat          Float?
  ingredients  Json
  instructions Json
  tips         String?
  isPublished  Boolean          @default(true)
  isFeatured   Boolean          @default(false)
  createdAt    DateTime         @default(now())
  updatedAt    DateTime         @updatedAt
  savedBy      SavedItem[]

  @@index([mealType])
  @@index([isPublished])
}

model SavedItem {
  id        String        @id @default(cuid())
  userId    String
  itemType  SavedItemType
  itemId    String
  recipeId  String?
  createdAt DateTime      @default(now())
  recipe    Recipe?       @relation(fields: [recipeId], references: [id], onDelete: Cascade)

  @@unique([userId, itemType, itemId])
  @@index([userId])
}

model WeightManagementPreferences {
  id                     String   @id @default(cuid())
  userId                 String   @unique
  hasCompletedOnboarding Boolean  @default(false)
  onboardingStep         Int      @default(0)
  weightUnit             String   @default("KG")
  dietaryRequirements    String[] @default([])
  allergies              String[] @default([])
  dailyCalorieGoal       Int?
  dailyWaterGoal         Float?
  trackingReminders      Boolean  @default(true)
  reminderTime           String?
  createdAt              DateTime @default(now())
  updatedAt              DateTime @updatedAt

  @@index([userId])
}

model SupportTicket {
  id          String    @id @default(cuid())
  userId      String
  subject     String
  category    String
  message     String
  status      String    @default("OPEN")
  priority    String    @default("NORMAL")
  response    String?
  respondedBy String?
  respondedAt DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@index([userId])
  @@index([status])
}

model Prescription {
  id                  String               @id @default(cuid())
  patientId           String
  medicationName      String
  genericName         String?
  strength            String
  form                MedicationForm       @default(TABLET)
  dosage              String
  frequency           String
  instructions        String?
  route               String?
  quantity            Int
  quantityUnit        String               @default("tablets")
  refillsTotal        Int                  @default(0)
  refillsRemaining    Int                  @default(0)
  daysSupply          Int?
  prescribedAt        DateTime             @default(now())
  startDate           DateTime             @default(now())
  endDate             DateTime?
  lastFilledAt        DateTime?
