  appointmentConfirmed Boolean @default(false)
  medicationsChecked   Boolean @default(false)
  allergiesChecked     Boolean @default(false)
  riskFlagsChecked     Boolean @default(false)
  bmiChecked           Boolean @default(false)
  briefAttached        Boolean @default(false)
